# Generated by FrogOps (deterministic bootstrap)
ARG DOCKER_REGISTRY=docker.io
ARG BASE_REPO=library

FROM ${DOCKER_REGISTRY}/${BASE_REPO}/node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci --no-audit --ignore-scripts || npm install --no-audit --ignore-scripts
COPY . .
RUN npm run build || true

FROM ${DOCKER_REGISTRY}/${BASE_REPO}/node:20-alpine AS runtime
WORKDIR /app
COPY --from=build /app .
RUN addgroup -S app && adduser -S -G app app
USER app
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD wget -qO- http://localhost:3000/health || exit 1
CMD ["npm", "start"]
