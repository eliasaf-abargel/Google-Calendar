# Generated by FrogOps (deterministic bootstrap)
ARG DOCKER_REGISTRY=docker.io
ARG BASE_REPO=library

FROM ${DOCKER_REGISTRY}/${BASE_REPO}/node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci --no-audit --ignore-scripts || npm install --no-audit --ignore-scripts
COPY . .
RUN npm run build

FROM ${DOCKER_REGISTRY}/${BASE_REPO}/nginx:1.25-alpine AS runtime
RUN rm -rf /usr/share/nginx/html/*
COPY --from=build /app/build /usr/share/nginx/html
USER nginx
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD wget -qO- http://localhost:8080/ || exit 1
CMD ["nginx", "-g", "daemon off;"]
